# poly-dispute-research
# Fill these in:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=-

# Tuning
LIMIT=500
MAX_PER_MESSAGE=30

# Paths (keep everything in one folder)
STATE_PATH=./state/state.json

# Skip events whose JSON contains any of these as whole word (case-sensitive, comma-separated)
BLACKLIST_KEYWORDS=Sport,football,NFL,Sports,Games
